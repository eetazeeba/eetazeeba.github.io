---
bodyClass: page-blog page-atmosphere page-atmosphere--vellum
---

<article class="l-page-shell l-module-stack blog-article-page">
  <header class="card card-impact blog-article-hero" aria-labelledby="blog-article-heading">
    <div class="l-grid--2 blog-article-hero__layout">
      <div class="l-module-stack">
        <h1 class="card-title display-title" id="blog-article-heading">{{ entry.title }}</h1>
        <p class="blog-article-lede">{{ entry.summary }}</p>
      </div>

      <aside class="blog-article-hero__meta" aria-label="Article metadata">
        <div class="blog-meta-panel">
          <ul class="blog-meta-list" role="list">
            {% for item in entry.metadataItems %}
            <li class="blog-meta-item">
              {% if item.href %}
              <a class="blog-meta-link"
                href="{{ item.href }}"
                data-analytics-event="blog_engagement"
                data-analytics-surface="article_hero_metadata"
                data-analytics-bucket="{{ entry.bucket }}">
                {{ item.label }}
              </a>
              {% else %}
              <span>{{ item.label }}</span>
              {% endif %}
            </li>
            {% endfor %}
          </ul>
          {% if entry.articleDetailItems.length %}
          <ul class="blog-meta-list blog-meta-list--secondary" role="list">
            {% for item in entry.articleDetailItems %}
            <li class="blog-meta-item">
              <span>{{ item.label }}</span>
            </li>
            {% endfor %}
          </ul>
          {% endif %}
        </div>
      </aside>
    </div>
  </header>

  <div class="l-grid--2 blog-article-layout">
    <section class="card blog-article-body" aria-labelledby="blog-article-body-heading">
      <h2 class="blog-sr-only" id="blog-article-body-heading">Article body</h2>
      <div class="blog-prose">
        {{ entry.htmlContent | safe }}
      </div>
    </section>

    <aside class="module-card-stack is-compact blog-article-sidebar" aria-label="Article pathways">
      <section class="card">
        <p class="blog-kicker">Keep reading</p>
        <h2 class="card-title">More from the blog</h2>
        {% if entry.relatedBlogEntries.length %}
        <div class="module-card-stack is-compact">
          {% for related in entry.relatedBlogEntries %}
          <article class="blog-inline-card">
            <h3 class="card-title">{{ related.title }}</h3>
            <div class="blog-meta-panel" aria-label="Post metadata">
              <ul class="blog-meta-list" role="list">
                {% for item in related.metadataItems %}
                <li class="blog-meta-item">
                  {% if item.href %}
                  <a class="blog-meta-link"
                    href="{{ item.href }}"
                    data-analytics-event="blog_engagement"
                    data-analytics-surface="related_post_metadata"
                    data-analytics-bucket="{{ related.bucket }}">
                    {{ item.label }}
                  </a>
                  {% else %}
                  <span>{{ item.label }}</span>
                  {% endif %}
                </li>
                {% endfor %}
              </ul>
            </div>
            <p>{{ related.summary }}</p>
            <a class="blog-inline-link"
              href="{{ related.url }}"
              data-analytics-event="related_post_click"
              data-analytics-surface="related_posts"
              data-analytics-entry="{{ related.title }}">
              Read related post
            </a>
          </article>
          {% endfor %}
        </div>
        {% else %}
        <p>Use the bucket hubs and curated blog landing page to find the next useful lane without getting buried in archive noise.</p>
        <div class="module-card-stack is-compact">
          <a class="btn btn--soft-emphasis"
            href="/blog/"
            data-analytics-event="blog_engagement"
            data-analytics-surface="article_fallback"
            data-analytics-destination="blog_hub">
            Back to the blog hub
          </a>
          {% if entry.bucketIsPublic %}
          <a class="btn btn--secondary"
            href="{{ entry.bucketUrl }}"
            data-analytics-event="blog_engagement"
            data-analytics-surface="article_fallback"
            data-analytics-bucket="{{ entry.bucket }}">
            Browse {{ entry.bucketTitle }}
          </a>
          {% endif %}
        </div>
        {% endif %}
      </section>

      <section class="card">
        <p class="blog-kicker">Need help?</p>
        <h2 class="card-title">Move from reading into real support</h2>
        <p>When the article stops being enough and the project needs structure, the next step should stay clear.</p>
        <div class="module-card-stack is-compact">
          <a class="btn"
            href="/services/production/"
            data-analytics-event="service_interest"
            data-analytics-service="production_support"
            data-analytics-surface="article_help">
            Explore production support
          </a>
          <a class="btn btn--secondary"
            href="/services/rates-quote/"
            data-analytics-event="service_interest"
            data-analytics-service="rates_quote"
            data-analytics-surface="article_help">
            Use the rates / quote path
          </a>
          <a class="blog-inline-link"
            href="/contact/work-with-us/"
            data-analytics-contact="work_with_us"
            data-analytics-surface="article_help">
            Prefer a direct conversation?
          </a>
        </div>
      </section>
    </aside>
  </div>
</article>
