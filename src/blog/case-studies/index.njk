---
layout: layouts/base.njk
title: Case Studies
bodyClass: page-blog page-atmosphere page-atmosphere--vellum
breadcrumbTitle: Case Studies
description: Browse Musifer case studies for applied breakdowns, process notes, and proof-oriented reading as that lane grows.
---
{% set bucket = blog.publicBucketMap["case-studies"] %}

<div class="l-page-shell l-module-stack blog-bucket-page">
  <section class="card card-impact blog-bucket-header" aria-labelledby="case-studies-heading">
    <h1 class="card-title display-title" id="case-studies-heading">{{ bucket.title }}</h1>
    <p class="blog-page-deck">{{ bucket.hubDescription }}</p>
  </section>

  <section class="card" aria-labelledby="case-studies-list-heading">
    <div class="blog-section-header">
      <div>
        <h2 class="card-title" id="case-studies-list-heading">What is live in this lane</h2>
        <p class="blog-section-copy">{{ bucket.displayMeta.countLabelLong }}</p>
      </div>
      <a class="btn btn--secondary"
        href="/blog/"
        data-analytics-event="blog_engagement"
        data-analytics-surface="bucket_header"
        data-analytics-bucket="case_studies"
        data-analytics-destination="blog_hub">
        Back to blog hub
      </a>
    </div>

    {% if bucket.entries.length %}
    <div class="module-card-stack">
      {% for entry in bucket.entries %}
      <article class="blog-bucket-entry">
        <h3 class="card-title">{{ entry.title }}</h3>
        <div class="blog-meta-panel" aria-label="Post metadata">
          <ul class="blog-meta-list" role="list">
            {% for item in entry.metadataItems %}
            <li class="blog-meta-item">
              {% if item.href %}
              <a class="blog-meta-link"
                href="{{ item.href }}"
                data-analytics-event="blog_engagement"
                data-analytics-surface="bucket_metadata"
                data-analytics-bucket="case_studies">
                {{ item.label }}
              </a>
              {% else %}
              <span>{{ item.label }}</span>
              {% endif %}
            </li>
            {% endfor %}
          </ul>
        </div>
        <p>{{ entry.summary }}</p>
        <a class="blog-inline-link"
          href="{{ entry.url }}"
          data-analytics-event="blog_engagement"
          data-analytics-surface="bucket_entries"
          data-analytics-bucket="case_studies"
          data-analytics-entry="{{ entry.title }}">
          Read case study
        </a>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <div class="blog-empty-state">
      <p>Case studies are part of the public structure now, but they are being held until there is enough real material to justify the lane.</p>
      <div class="blog-browse-links">
        <a class="btn"
          href="/blog/"
          data-analytics-event="blog_engagement"
          data-analytics-surface="bucket_empty_state"
          data-analytics-bucket="case_studies"
          data-analytics-destination="blog_hub">
          Return to the blog hub
        </a>
        <a class="btn btn--secondary"
          href="/services/rates-quote/"
          data-analytics-event="service_interest"
          data-analytics-service="rates_quote"
          data-analytics-surface="bucket_empty_state">
          Use the quote path
        </a>
      </div>
    </div>
    {% endif %}
  </section>
</div>
